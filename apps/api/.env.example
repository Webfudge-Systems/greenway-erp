# Production template — copy secrets from Railway → Greenway-Backend → Variables.
# Local dev: use `.env` (SQLite). Production deploy: Railway injects DATABASE_URL + REDIS_URL.
NODE_ENV=production
HOST=0.0.0.0
PORT=1337

# Generate each secret: openssl rand -base64 32
# APP_KEYS needs TWO comma-separated values (Strapi requirement)
APP_KEYS=replace_key_1,replace_key_2
API_TOKEN_SALT=replace_me
ADMIN_JWT_SECRET=replace_me
TRANSFER_TOKEN_SALT=replace_me
JWT_SECRET=replace_me
ENCRYPTION_KEY=replace_me

# PostgreSQL (Railway — reference Postgres → DATABASE_URL)
DATABASE_CLIENT=postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=5
SEED_DATA=false

# Public API URL — Railway production
PUBLIC_URL=https://greenway-backend-production.up.railway.app
STRAPI_ADMIN_BACKEND_URL=https://greenway-backend-production.up.railway.app

# CORS — production frontends (comma-separated, no spaces)
CORS_ORIGINS=https://orbit.greenway.webfudge.in,https://base.greenway.webfudge.in,https://erp.greenway.webfudge.in,https://greenwaymobility.in,https://www.greenwaymobility.in,https://accounts.greenwaymobility.in,https://pm.greenwaymobility.in

# Redis caching (Railway: link Redis service → reference REDIS_URL)
# REDIS_URL=redis://default:password@redis.railway.internal:6379
REDIS_ENABLED=true
CACHE_API_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_BODY_BYTES=5242880
CACHE_KEY_PREFIX=cache

# Platform super admin (first deploy only)
PLATFORM_ADMIN_EMAIL=superadmin@greenways.in
PLATFORM_ADMIN_PASSWORD=replace_me_strong_password
PLATFORM_ADMIN_FIRST_NAME=Platform
PLATFORM_ADMIN_LAST_NAME=Admin

# Local development overrides (.env):
# NODE_ENV=development
# DATABASE_CLIENT=sqlite
# DATABASE_FILENAME=.tmp/data.db
# REDIS_ENABLED=false
# CACHE_API_ENABLED=false
# SEED_DATA=true
