# Copy these into Railway → Greenway-Backend → Variables
# Postgres: use "Add reference" → Postgres → DATABASE_URL (do not paste manually)

NODE_ENV=production
HOST=0.0.0.0
# PORT is set automatically by Railway — do not override unless needed

# Generate each secret locally: openssl rand -base64 32
# APP_KEYS needs TWO comma-separated values (Strapi requirement)
APP_KEYS=replace_key_1,replace_key_2
API_TOKEN_SALT=replace_me
ADMIN_JWT_SECRET=replace_me
TRANSFER_TOKEN_SALT=replace_me
JWT_SECRET=replace_me
ENCRYPTION_KEY=replace_me

# Postgres in production (set DATABASE_CLIENT=postgres — required, same as webfudge-platform)
DATABASE_CLIENT=postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=5
SEED_DATA=false

# Public API URL — Railway production
PUBLIC_URL=https://greenway-backend-production.up.railway.app
STRAPI_ADMIN_BACKEND_URL=https://greenway-backend-production.up.railway.app

# CORS — Vercel/custom frontends (comma-separated, no spaces)
# *.vercel.app is already allowed by pattern in config/middlewares.js
CORS_ORIGINS=https://orbit.greenway.webfudge.in,https://base.greenway.webfudge.in,https://erp.greenway.webfudge.in,https://greenwaymobility.in,https://www.greenwaymobility.in,https://accounts.greenwaymobility.in,https://pm.greenwaymobility.in

# Redis caching (recommended for ERP list/read performance)
# Link Redis service -> add REDIS_URL reference
# REDIS_URL=redis://default:...@redis.railway.internal:6379
REDIS_ENABLED=true
CACHE_API_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_MAX_BODY_BYTES=5242880
CACHE_KEY_PREFIX=cache

# Optional: first-run platform admin
PLATFORM_ADMIN_EMAIL=superadmin@greenways.in
PLATFORM_ADMIN_PASSWORD=change_me_strong_password
PLATFORM_ADMIN_FIRST_NAME=Platform
PLATFORM_ADMIN_LAST_NAME=Admin

# Optional: re-run seed
# SEED_DATA=true
