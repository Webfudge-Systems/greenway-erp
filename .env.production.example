# Copy to .env for docker compose, or set in your hosting provider.
# Generate secrets: openssl rand -base64 32

# ─── PostgreSQL (docker compose service: postgres) ───────────────────────────
DATABASE_NAME=greenways
DATABASE_USERNAME=greenways
DATABASE_PASSWORD=change_me_strong_password

# ─── Strapi API (apps/api) ───────────────────────────────────────────────────
APP_KEYS=replace_with_comma_separated_keys
API_TOKEN_SALT=replace_me
ADMIN_JWT_SECRET=replace_me
TRANSFER_TOKEN_SALT=replace_me
JWT_SECRET=replace_me
ENCRYPTION_KEY=replace_me

# Optional: comma-separated extra CORS origins (preview URLs, staging domains)
# CORS_ORIGINS=https://staging.greenwaymobility.in,https://my-preview.vercel.app

# ─── Public URLs (Next.js apps — baked in at build time for Docker) ─────────
NEXT_PUBLIC_API_URL=https://api.greenwaymobility.in
NEXT_PUBLIC_ORG_MANAGER_URL=https://greenwaymobility.in
NEXT_PUBLIC_SITE_URL=https://greenwaymobility.in
NEXT_PUBLIC_ACCOUNTS_APP_URL=https://accounts.greenwaymobility.in
NEXT_PUBLIC_PM_APP_URL=https://pm.greenwaymobility.in

# Deprecated (still supported in org-manager lib/site.js)
# NEXT_PUBLIC_LANDING_URL=https://greenwaymobility.in
