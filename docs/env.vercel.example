# Vercel environment variables — all three frontend projects
# Copy into Vercel → Settings → Environment Variables (Production + Preview).
# Enable "Include source files outside of the Root Directory" on each project.

NEXT_IGNORE_INCORRECT_LOCKFILE=1

# Shared across all frontends
NEXT_PUBLIC_API_URL=https://greenway-backend-production.up.railway.app
NEXT_PUBLIC_ORG_MANAGER_URL=https://orbit.greenway.webfudge.in
NEXT_PUBLIC_ACCOUNTS_APP_URL=https://base.greenway.webfudge.in
NEXT_PUBLIC_PM_APP_URL=https://erp.greenway.webfudge.in

# Organization Manager only
NEXT_PUBLIC_SITE_URL=https://orbit.greenway.webfudge.in

# PM only
NEXT_PUBLIC_CRM_APP_URL=https://base.greenway.webfudge.in
NEXT_PUBLIC_TRIAL_DAYS_REMAINING=12

# Per-project copy-paste files:
#   apps/organization-manager/.env.vercel
#   apps/accounts/.env.vercel
#   apps/pm/.env.vercel

# Deployed URLs:
#   Organization Manager — https://orbit.greenway.webfudge.in
#   Accounts           — https://base.greenway.webfudge.in
#   PM                 — https://erp.greenway.webfudge.in
#   Backend (Railway)  — https://greenway-backend-production.up.railway.app
