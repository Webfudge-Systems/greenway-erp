NODE_ENV=development
HOST=0.0.0.0
PORT=1337

APP_KEYS=toBeModified1,toBeModified2
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# ─── Database ───────────────────────────────────────────────────────────────
# SQLite (local dev only)
DATABASE_CLIENT=sqlite

# PostgreSQL (production — Railway, Docker, etc.)
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/railway
# DATABASE_SSL=true
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# Or discrete vars (without DATABASE_URL):
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=greenways
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your_strong_password

# ─── Platform super admin (seeded on bootstrap) ─────────────────────────────
# PLATFORM_ADMIN_EMAIL=superadmin@greenways.in
# PLATFORM_ADMIN_PASSWORD=change_me
# PLATFORM_ADMIN_FIRST_NAME=Platform
# PLATFORM_ADMIN_LAST_NAME=Admin
# SEED_DATA=true

# ─── Production (Railway / Vercel) ──────────────────────────────────────────
# NODE_ENV=production
# PUBLIC_URL=https://your-api.up.railway.app
# STRAPI_ADMIN_BACKEND_URL=https://your-api.up.railway.app
# CORS_ORIGINS=https://org-manager.vercel.app,https://accounts.vercel.app

# ─── Redis (optional caching for ERP read APIs) ─────────────────────────────
# Railway: link Redis service to API and reference REDIS_URL variable.
# REDIS_URL=redis://default:password@redis.railway.internal:6379
# REDIS_ENABLED=true
# CACHE_API_ENABLED=true
# CACHE_TTL_SECONDS=300
# CACHE_MAX_BODY_BYTES=5242880
# CACHE_KEY_PREFIX=cache

# Full Railway template: apps/api/.env.railway.example
