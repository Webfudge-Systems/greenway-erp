# Production template — copy to .env.local for local dev or .env.production for prod builds.
# No secrets in frontend env; values below are the deployed URLs.
NEXT_IGNORE_INCORRECT_LOCKFILE=1

NEXT_PUBLIC_API_URL=https://greenway-backend-production.up.railway.app
NEXT_PUBLIC_ORG_MANAGER_URL=https://orbit.greenway.webfudge.in
NEXT_PUBLIC_ACCOUNTS_APP_URL=https://base.greenway.webfudge.in
NEXT_PUBLIC_PM_APP_URL=https://erp.greenway.webfudge.in
NEXT_PUBLIC_CRM_APP_URL=https://base.greenway.webfudge.in
NEXT_PUBLIC_TRIAL_DAYS_REMAINING=12

