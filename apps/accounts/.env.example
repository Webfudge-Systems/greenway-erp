# Suppresses Next.js lockfile/SWC auto-patch warnings in npm workspaces (local dev only)
NEXT_IGNORE_INCORRECT_LOCKFILE=1

NEXT_PUBLIC_API_URL=http://localhost:1337
NEXT_PUBLIC_ACCOUNTS_APP_URL=http://localhost:3001
NEXT_PUBLIC_PM_APP_URL=http://localhost:3002
NEXT_PUBLIC_ORG_MANAGER_URL=http://localhost:3000
# Deprecated alias: NEXT_PUBLIC_LANDING_URL
NEXT_PUBLIC_TRIAL_DAYS_REMAINING=12

# Production — see .env.production.example at repo root
# NEXT_PUBLIC_API_URL=https://api.greenwaymobility.in
# NEXT_PUBLIC_ORG_MANAGER_URL=https://greenwaymobility.in
# NEXT_PUBLIC_ACCOUNTS_APP_URL=https://accounts.greenwaymobility.in
# NEXT_PUBLIC_PM_APP_URL=https://pm.greenwaymobility.in