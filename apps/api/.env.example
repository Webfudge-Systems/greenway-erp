NODE_ENV=development
HOST=0.0.0.0
PORT=1337APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# ─── Database ───────────────────────────────────────────────────────────────
# SQLite (default — development only, NOT suitable for production SAAS)
DATABASE_CLIENT=sqlite

# PostgreSQL (recommended for production / multi-tenant SAAS)
# 1. Install the driver:  npm install pg  (in apps/backend)
# 2. Set DATABASE_CLIENT=postgres  and fill in the vars below.
# DATABASE_CLIENT=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=webfudge_platform
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your_strong_password
# DATABASE_SSL=false
# Remote Postgres (e.g. Supabase): if Node errors on TLS chain, set DATABASE_SSL=true and try:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# (Prefer fixing CA trust / NODE_EXTRA_CA_CERTS in production.)
# DATABASE_SCHEMA=public
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10
# Or use a full connection string (e.g. on Supabase / Railway / Neon):
# DATABASE_URL=postgresql://postgres:password@db.host:5432/webfudge_platform

# ─── Platform super admin (seeded on bootstrap) ─────────────────────────────
# PLATFORM_ADMIN_EMAIL=superadmin@greenways.in
# PLATFORM_ADMIN_PASSWORD=Greenways@2026!
# PLATFORM_ADMIN_FIRST_NAME=Platform
# PLATFORM_ADMIN_LAST_NAME=Admin
# Default apps (CRM, PM, Accounts) + modules seed automatically when the DB has
# no App entries. Set SEED_DATA=true to run the seed again (updates by slug).
# SEED_DATA=true

# ─── Production / staging ───────────────────────────────────────────────────
# NODE_ENV=production
# DATABASE_CLIENT=postgres
# CORS_ORIGINS=https://staging.example.com,https://preview.vercel.app